# ─────────────────────────────────────────────────────────────
# Arena — environment variables template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Required — generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate-with-python3-c-import-secrets-print-secrets-token-hex-32

# Required — Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Optional — Grok API key (Grok personas fall back to Claude if unset)
GROK_API_KEY=xai-...

# Environment: "development" or "production"
# In production: stack traces are hidden from clients, HSTS header added,
# and cookies are set with secure=True (HTTPS only).
ENVIRONMENT=development

# Comma-separated list of allowed CORS origins
# Development default:
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production example:
# ALLOWED_ORIGINS=https://yourdomain.com

# Database (auto-configured — SQLite used if unset)
# DATABASE_URL=postgresql://user:password@host:5432/arena