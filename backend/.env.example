# Anthropic API Key (required)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# LLM Configuration
DEFAULT_MODEL=claude-sonnet-4-20250514
MAX_TOKENS=1024
TIMEOUT_SECONDS=30

# Database — PostgreSQL primary, SQLite fallback for local dev
DATABASE_URL=postgresql://postgres:password@localhost:5432/arena
DATABASE_URL_FALLBACK=sqlite:///./arena.db

# Auth / JWT — generate a strong random secret for production
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
