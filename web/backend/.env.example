# ═══════════════════════════════════════════════════════════════
# Arena - Backend Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ═══════════════════════════════════════════════════════════════

# ── Environment ────────────────────────────────────────────────
# Set to 'production' on Render/AWS/etc.
ENVIRONMENT=development

# ── Security ───────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── API Keys ───────────────────────────────────────────────────
# REQUIRED - Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OPTIONAL - Fallback to Claude when not set
OPENAI_API_KEY=
GROK_API_KEY=
DEEPSEEK_API_KEY=

# ── Database ───────────────────────────────────────────────────
# PostgreSQL recommended for production
# SQLite is used as fallback when not set
DATABASE_URL=

# ── CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Frontend URL ───────────────────────────────────────────────
# Used for shared links, room invites, etc.
FRONTEND_PUBLIC_URL=http://localhost:5173

# ── Admin ──────────────────────────────────────────────────────
ADMIN_EMAIL=

# ── Encryption ─────────────────────────────────────────────────
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required for MCP token encryption at rest (must be 44-char Fernet key)
ENCRYPTION_KEY=

# ── Authentication ─────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=240
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Rate Limits ────────────────────────────────────────────────
GUEST_DAILY_LIMIT=5
REGISTERED_DAILY_LIMIT=7
PRO_WINDOW_MESSAGES=45
PRO_WINDOW_HOURS=5

# ── Server (rarely need to change) ─────────────────────────────
# HOST=0.0.0.0
# PORT=8000
# DEBUG=false

# ── LLM (defaults are fine for most setups) ──────────────────────
# DEFAULT_MODEL=claude-sonnet-4-20250514
# MAX_TOKENS=1024
# TIMEOUT_SECONDS=30

# ── App ─────────────────────────────────────────────────────────
# APP_VERSION=1.0.0

# ── Razorpay (Payments) ───────────────────────────────────────
# Optional until billing is enabled
RAZORPAY_API_KEY=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Plan IDs (set after creating plans in Razorpay dashboard)
RAZORPAY_PLUS_MONTHLY_PLAN_ID=
RAZORPAY_PLUS_ANNUAL_PLAN_ID=
RAZORPAY_PRO_MONTHLY_PLAN_ID=
RAZORPAY_PRO_ANNUAL_PLAN_ID=
RAZORPAY_AGENT_ADDON_PLAN_ID=
